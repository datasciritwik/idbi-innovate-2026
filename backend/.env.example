# Modal app (see modal_deploy/wren_app.py) hosting LLMApp/TTSApp/STTApp.
# The backend calls these directly over Modal RPC (no HTTP endpoint) — set
# these only if you rename the app/classes in wren_app.py.
MODAL_APP_NAME=wren-app
MODAL_LLM_CLASS=LLMApp
MODAL_TTS_CLASS=TTSApp
MODAL_STT_CLASS=STTApp

# Modal API credentials — only needed where there's no `modal token new`-
# authenticated ~/.modal.toml (e.g. a deployed server). Leave unset locally;
# the Modal client falls back to your CLI profile. An empty string here would
# override that fallback, so don't set these unless you're actually providing
# a token.
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# Where the synthetic dataset lives. Locally this points at the sibling
# ../data/output produced by data/scripts/generate_all.py. At deploy time,
# bake the same three files into the image and point this at that path
# instead (the dataset is intentionally not committed to git).
DATA_DIR=../data/output

# Comma-separated list of origins allowed to call this API (the frontend dev
# server, and later the deployed frontend URL).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5173/

# --- Anonymous session / access control (no user login exists) ---

# Signs the anonymous session JWT. MUST be a real random secret at deploy
# time — do not ship the dev default.
JWT_SECRET=dev-only-insecure-secret-change-me
SESSION_TOKEN_TTL_MINUTES=120

# Only set to true if this API sits behind a reverse proxy that itself sets
# X-Forwarded-For — otherwise a client can spoof this header to dodge
# IP-based quota.
TRUST_PROXY_HEADERS=false

# Where the per-IP usage ledger's SQLite file lives. At deploy time point
# this at a path on persistent storage so quota survives restarts.
QUOTA_DB_PATH=./data/quota.db

# No-auth usage cap: each IP gets QUOTA_SECONDS of chat "talk time" per
# rolling QUOTA_WINDOW_HOURS window. CHAT_TURN_COST_SECONDS is charged per
# chat/trigger call as a stand-in until turns have a real audio duration.
QUOTA_SECONDS=600
QUOTA_WINDOW_HOURS=24
CHAT_TURN_COST_SECONDS=20

# Concurrency gate in front of GPU-bound work (the self-hosted LLM/TTS
# endpoints). Requests beyond MAX_CONCURRENT_GPU_CALLS wait up to
# GPU_QUEUE_TIMEOUT_SECONDS, then get a 503 telling them to retry.
MAX_CONCURRENT_GPU_CALLS=2
GPU_QUEUE_TIMEOUT_SECONDS=8
