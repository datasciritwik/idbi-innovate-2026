# Anthropic API key for the conversational layer (Wren's responses).
ANTHROPIC_API_KEY=

# Where the synthetic dataset lives. Locally this points at the sibling
# ../data/output produced by data/scripts/generate_all.py. At deploy time,
# bake the same three files into the image and point this at that path
# instead (the dataset is intentionally not committed to git).
DATA_DIR=../data/output

# Comma-separated list of origins allowed to call this API (the frontend dev
# server, and later the deployed frontend URL).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5173/
